# VPS production template for deliver-impact.com (72.61.5.60).
#   cp .env.vps.example .env
# Generate secrets: openssl rand -hex 32
# KEYCLOAK_CLIENT_SECRET must match infra/keycloak/landscrape-realm.json on first boot.
# See docs/deploy-vps.md
#
# Fast deploy (recommended): include compose.registry.yml and pull from GHCR
#   COMPOSE_FILE=compose.yaml:compose.vps.yml:compose.traefik.yml:compose.registry.yml
# Images are built by .github/workflows/docker-publish.yml (push to main).

# --- GHCR images (pull-only on VPS; lowercase GitHub owner) ---
LANDSCRAPE_IMAGE_REGISTRY=ghcr.io
LANDSCRAPE_IMAGE_OWNER=CHANGE_ME_GITHUB_OWNER_LOWERCASE
LANDSCRAPE_IMAGE_TAG=prod

# --- PostgreSQL ---
POSTGRES_DB=landscrape
POSTGRES_USER=landscrape
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
DATABASE_URL=postgresql://landscrape:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/landscrape

REDIS_URL=redis://redis:6379

# --- MinIO / S3 (internal only on VPS) ---
MINIO_ROOT_USER=landscrape
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
STORAGE_ENDPOINT=http://minio:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=landscrape
STORAGE_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
STORAGE_BUCKET=landscrape-artifacts
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_BASE_URL=http://minio:9000

# --- Ollama ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_AGENT_MODEL=llama3.2:3b
LANDSCRAPE_OLLAMA_MAX_CONCURRENT=1
LANDSCRAPE_OLLAMA_GLOBAL_MAX_CONCURRENT=1
LANDSCRAPE_OLLAMA_PIPELINE_TIMEOUT_MS=120000

# --- Agent (user chat; agent-enrich is off by default — use --profile enrich-agent locally) ---
AGENT_PORT=4010
AGENT_INTERNAL_URL=http://agent:4010
LANDSCRAPE_REFERENCE_TOOLS=mcp
LANDSCRAPE_ENRICH_USE_AGENT=false
LANDSCRAPE_AGENT_TURN_CONCURRENCY=1

MCP_FDA_URL=http://mcp-fda:4020
MCP_PUBMED_URL=http://mcp-pubmed:4021
MCP_CLINICALTRIALS_URL=http://mcp-clinicaltrials:4022

NODE_ENV=production
API_PORT=4000
WEB_PORT=3000
ADMIN_PORT=3001

LANDSCRAPE_TENANT_SLUG=ayvakit
LANDSCRAPE_SEED=true
LANDSCRAPE_INTERNAL_API_KEY=CHANGE_ME_INTERNAL_API_KEY

LANDSCRAPE_CONTACT_EMAIL=matt@boro-tech.com
LANDSCRAPE_CONTACT_URL=https://deliver-impact.com

# Required to store encrypted connector secrets (X/Twitter cookies, portal logins, API tokens, etc.).
# Generate: openssl rand -hex 32
LANDSCRAPE_CREDENTIALS_KEY=CHANGE_ME_CREDENTIALS_KEY

NEXT_PUBLIC_API_BASE_URL=https://deliver-impact.com
# Auth redirects and middleware (must match Traefik Host rules in compose.traefik.yml).
WEB_PUBLIC_URL=https://deliver-impact.com
API_INTERNAL_URL=http://api:4000
ADMIN_BASE_URL=https://deliver-impact.com/admin

# --- Authentication ---
AUTH_ENABLED=true
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=landscrape
KEYCLOAK_CLIENT_ID=landscrape-web
KEYCLOAK_CLIENT_SECRET=landscrape-web-secret-change-in-prod
KEYCLOAK_ISSUER=http://keycloak:8080/realms/landscrape
AUTH_COOKIE_DOMAIN=.deliver-impact.com
AUTH_CORS_ORIGINS=https://deliver-impact.com,https://www.deliver-impact.com
# Session lifetime in Redis (seconds). Defaults to Keycloak refresh lifetime or 259200 (3 days).
# SESSION_TTL_SECONDS=259200
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK_ADMIN_PASSWORD

# --- VPS CPU throttles (also set in compose.vps.yml; keep in sync) ---
LANDSCRAPE_SCHEDULER_INTERVAL_MS=120000
LANDSCRAPE_SCHEDULER_BURST_LIMIT=1
LANDSCRAPE_EMBED_BACKFILL_INTERVAL_MS=900000
LANDSCRAPE_EMBED_BACKFILL_BATCH_SIZE=5
LANDSCRAPE_EMBED_BACKFILL_MAX_QUEUE_DEPTH=20
LANDSCRAPE_EMBED_BACKFILL_ENABLED=true
LANDSCRAPE_ENRICH_IMPORTANCE_THRESHOLD=88
LANDSCRAPE_PRODUCT_ENRICH_ENABLED=false
LANDSCRAPE_COMPETITOR_RENDER_MODE=fetch
LANDSCRAPE_LOG_QUEUE_DEPTH=true

# --- X/social (optional; requires: docker compose --profile social up -d) ---
LANDSCRAPE_X_BACKEND=api
XACTIONS_API_URL=http://xactions-api:3001

XACTIONS_POSTGRES_PASSWORD=CHANGE_ME_XACTIONS_POSTGRES_PASSWORD
XACTIONS_JWT_SECRET=CHANGE_ME_XACTIONS_JWT_SECRET
XACTIONS_SESSION_SECRET=CHANGE_ME_XACTIONS_SESSION_SECRET
