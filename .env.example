# Copy to .env before running Docker Compose:
#   cp .env.example .env
#
# VPS production (deliver-impact.com): see .env.vps.example and docs/deploy-vps.md
# Every variable below is REQUIRED unless explicitly marked optional.
# The worker will crash at startup with a clear error if any required value is missing.

# --- PostgreSQL (compose + apps) ---
POSTGRES_DB=landscrape
POSTGRES_USER=landscrape
POSTGRES_PASSWORD=landscrape_secure_password
DATABASE_URL=postgresql://landscrape:landscrape_secure_password@postgres:5432/landscrape

REDIS_URL=redis://redis:6379

# --- MinIO / S3 ---
MINIO_ROOT_USER=landscrape
MINIO_ROOT_PASSWORD=landscrape_minio_password
STORAGE_ENDPOINT=http://minio:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=landscrape
STORAGE_SECRET_KEY=landscrape_minio_password
STORAGE_BUCKET=landscrape-artifacts
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_BASE_URL=http://localhost:9000

# --- Ollama (model is pulled by ollama-init on first boot; ~2.0 GB for llama3.2:3b).
#     If you switch to a larger model (e.g. llama3.1:8b) ensure Docker Desktop has
#     at least 8 GiB allocated, otherwise the worker will crash on the first
#     generateSummary call with "model requires more system memory". ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
# Agent orchestration model (defaults to OLLAMA_MODEL; same 3B keeps RAM ~4 GiB)
OLLAMA_AGENT_MODEL=llama3.2:3b

# --- Agent service ---
AGENT_PORT=4010
AGENT_INTERNAL_URL=http://agent:4010
# Reference tool backend for agent: mcp | native | auto (default auto)
LANDSCRAPE_REFERENCE_TOOLS=mcp
# Use agent for high-importance signal enrichment (falls back to native tools on error).
# agent-enrich service: docker compose --profile enrich-agent up -d agent-enrich
LANDSCRAPE_ENRICH_USE_AGENT=true
# VPS tuning: see .env.vps.example (LANDSCRAPE_COMPETITOR_RENDER_MODE, LANDSCRAPE_OLLAMA_GLOBAL_MAX_CONCURRENT, etc.)
# When true, standard "Generate Briefing" uses agent path
# LANDSCRAPE_DEFAULT_AGENT_BRIEF=false
# Agent inference: ollama (default) or openai_compat for hosted CPU-friendly models
# AGENT_INFERENCE_BACKEND=ollama
# OPENAI_COMPAT_BASE_URL=https://api.openrouter.ai/api/v1
# OPENAI_COMPAT_API_KEY=
# OPENAI_COMPAT_MODEL=

# --- MCP Clinical Reference Kit sidecars (started by default in compose) ---
MCP_FDA_URL=http://mcp-fda:4020
MCP_PUBMED_URL=http://mcp-pubmed:4021
MCP_CLINICALTRIALS_URL=http://mcp-clinicaltrials:4022

# --- Runtime ---
NODE_ENV=production
API_PORT=4000
WEB_PORT=3000
ADMIN_PORT=3001

LANDSCRAPE_TENANT_SLUG=ayvakit
LANDSCRAPE_SEED=true
LANDSCRAPE_INTERNAL_API_KEY=replace_me_change_in_prod
# Mutating API routes (POST/PATCH connectors and sources) require header:
#   X-Landscrape-Internal-Key: <same value as LANDSCRAPE_INTERNAL_API_KEY>

# --- Polite-bot contact identity (advertised in User-Agent and From headers
#     so site owners have a real path to reach us if they object to traffic) ---
LANDSCRAPE_CONTACT_EMAIL=matt@boro-tech.com
LANDSCRAPE_CONTACT_URL=https://boro-tech.com

# Browser and same-machine tools (curl, etc.). Compose publishes the API on this port.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# Public site origin for auth redirects (must match how users reach the web app).
WEB_PUBLIC_URL=http://localhost:3000
# Admin console URL (web app shows an Admin link for users with the admin role).
ADMIN_BASE_URL=http://localhost:3001

# Server-side fetch from Next.js containers to the API service.
API_INTERNAL_URL=http://api:4000

# --- Authentication (Keycloak) ---
# Session length (access + SSO) is 3 days — see infra/keycloak/landscrape-realm.json.
# After changing lifetimes, recreate Keycloak or update realm in Admin Console, then sign in again.
AUTH_ENABLED=true
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=landscrape
KEYCLOAK_CLIENT_ID=landscrape-web
KEYCLOAK_CLIENT_SECRET=landscrape-web-secret-change-in-prod
KEYCLOAK_ISSUER=http://keycloak:8080/realms/landscrape
# 32+ character secret for signing session cookies (generate a unique value in production).
AUTH_COOKIE_SECRET=landscrape-auth-cookie-secret-change-me-32chars
# Share login between web and admin subdomains in production (e.g. .deliver-impact.com).
# AUTH_COOKIE_DOMAIN=
# Session TTL in Redis (seconds). Defaults to Keycloak refresh lifetime or 259200.
# SESSION_TTL_SECONDS=259200
# Cookie Secure flag (default: true when NODE_ENV=production).
# AUTH_COOKIE_SECURE=false
# Alternative for local-only dev: NODE_ENV=development (also disables Secure cookies).
# NODE_ENV=development
# Comma-separated origins allowed by the API CORS middleware when AUTH_ENABLED=true.
AUTH_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# Keycloak master admin (compose keycloak service only; not used by apps).
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- Multi-worker platform (optional; defaults suit docker compose) ---
# LANDSCRAPE_WORKER_ROLE=full
# LANDSCRAPE_QUEUE_PREFIX=landscrape
# LANDSCRAPE_EMBEDDING_MODEL=nomic-embed-text
# LANDSCRAPE_CREDENTIALS_KEY=
# LANDSCRAPE_INGEST_CONCURRENCY=2
# LANDSCRAPE_SOCIAL_CONCURRENCY=1
# LANDSCRAPE_X_MIN_GAP_MS=3000
# X ingest backend: api (XActions browser stack) | http (in-process GraphQL, dev fallback)
# LANDSCRAPE_X_BACKEND=api
# XACTIONS_API_URL=http://xactions-api:3001
# XACTIONS_API_TIMEOUT_MS=120000

# --- XActions stack (compose: xactions-postgres, xactions-redis, xactions-api, xactions-worker) ---
XACTIONS_POSTGRES_PASSWORD=xactions_dev_password_change_me
XACTIONS_JWT_SECRET=xactions-jwt-secret-change-me-in-production
XACTIONS_SESSION_SECRET=xactions-session-secret-change-me
# Set on xactions-api / xactions-worker only (disables x402 micropayments on /api/ai/*)
# X402_DISABLED=true
# LANDSCRAPE_SCHEDULER_INTERVAL_MS=60000
# LANDSCRAPE_SCHEDULER_BURST_LIMIT=8
# LANDSCRAPE_LOG_QUEUE_DEPTH=true
# LANDSCRAPE_OLLAMA_PIPELINE_TIMEOUT_MS=120000
# LANDSCRAPE_OLLAMA_MAX_CONCURRENT=1
# LANDSCRAPE_RECONCILE_INTERVAL_MS=900000
# LANDSCRAPE_EMBED_BACKFILL_INTERVAL_MS=300000
# LANDSCRAPE_IMAP_HOST=
# LANDSCRAPE_IMAP_PORT=993
# LANDSCRAPE_IMAP_USER=
# LANDSCRAPE_IMAP_PASSWORD=
# LANDSCRAPE_IMAP_TLS=true
# Set to "true" for the old single-tenant 15m loop without Redis queues:
# LANDSCRAPE_WORKER_ROLE=legacy

# --- HTTP politeness (optional) ---
# LANDSCRAPE_FETCH_MIN_GAP_MS=5000
# LANDSCRAPE_EUTILS_MIN_GAP_MS=150

# --- NCBI E-utilities (optional; higher rate limits for PubMed/E-utilities) ---
# Register at https://www.ncbi.nlm.nih.gov/account/ — used by worker, native tools, MCP sidecars
# NCBI_API_KEY=

# --- openFDA (optional; higher rate limits for regulatory openfda provider + tools) ---
# Register at https://open.fda.gov/apis/authentication/ — used by worker, native tools, MCP sidecars
# OPENFDA_API_KEY=
